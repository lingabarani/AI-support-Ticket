PORT=5000
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:5173
QUICKSIGHT_ALLOWED_DOMAINS=http://localhost:5173,http://127.0.0.1:5173,https://your-production-domain.example

# Database
DATABASE_PROVIDER=mongodb
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DATABASE=customer_support_ai
DDB_TICKETS_TABLE=support-ticket-ai-linga-dev-tickets
DDB_AI_RESULTS_TABLE=support-ticket-ai-linga-dev-ai-results
DDB_TICKETS_KEY_FIELD=ticket_id
DDB_AI_RESULTS_KEY_FIELD=result_id

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI Provider
AI_PROVIDER=bedrock
ENABLE_EXTERNAL_AI=false
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_PRIMARY_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_FALLBACK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_ANALYZE_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_CLAUDE_SONNET_MODEL_ID=
BEDROCK_CLAUDE_OPUS_MODEL_ID=
BEDROCK_TIMEOUT_MS=25000
BEDROCK_MAX_RETRIES=2
BEDROCK_ANALYZE_CONFIDENCE_THRESHOLD=0.75
BEDROCK_ANALYZE_MAX_TOKENS=1000
BEDROCK_ANALYZE_TEMPERATURE=0
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_AGENT_SESSION_PREFIX=aisupport
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Storage and Analytics
RAW_BUCKET=your-raw-support-data-bucket
ANALYTICS_BUCKET=your-analytics-output-bucket
ATHENA_DATABASE=customer_support_ai
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://your-athena-query-results/
DYNAMODB_TICKETS_TABLE=SupportTickets
DYNAMODB_USERS_TABLE=SupportUsers
LAMBDA_TICKET_PROCESSOR=ai-support-ticket-processor

# QuickSight
QUICKSIGHT_NAMESPACE=default
QUICKSIGHT_USER_ARN=arn:aws:quicksight:us-east-1:123456789012:user/default/your-user
QS_DASHBOARD_SUPPORT_AGENT=replace-with-support-agent-dashboard-id
QS_DASHBOARD_TEAM_MANAGER=replace-with-team-manager-dashboard-id
QS_DASHBOARD_BUSINESS_EXECUTIVE=replace-with-business-executive-dashboard-id
QS_ANALYSIS_SUPPORT_AGENT=replace-with-support-agent-analysis-id
QS_ANALYSIS_TEAM_MANAGER=replace-with-team-manager-analysis-id
QS_ANALYSIS_BUSINESS_EXECUTIVE=replace-with-business-executive-analysis-id
